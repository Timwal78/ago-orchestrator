# ============================================================
# A.G.O. — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# === RECON SWARM ===
SERP_API_KEY=your_serp_api_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2
RECON_INTERVAL_SECONDS=300
WORKER_POOL_SIZE=50

# === ASSET FORGE ===
OPENROUTER_API_KEY=your_openrouter_key
ANTHROPIC_API_KEY=your_anthropic_key
MODEL=anthropic/claude-sonnet-4-6
MAX_TOKENS=2000
FORGE_CONCURRENCY=5

# === SYNDICATE ROUTER ===
DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/xxx,https://discord.com/api/webhooks/yyy
PARTNER_API_URLS=https://partner1.com/api,https://partner2.com/api
PARTNER_API_KEYS=key1,key2
RETRY_MAX=3
RETRY_BACKOFF_MS=2000

# === SCHEMA ENGINE ===
DOMAIN=https://www.scriptmasterlabs.com
GITHUB_TOKEN=your_github_pat
GITHUB_REPO=Timwal78/SML_Portfolio
SCHEMA_PUSH_INTERVAL_SECONDS=3600
